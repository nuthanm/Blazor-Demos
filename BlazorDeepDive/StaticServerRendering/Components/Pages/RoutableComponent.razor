@page "/routable-component"
@rendermode InteractiveServer
@using StaticServerRendering.Components.SubComponents;
@* 
<h3>Routable Component</h3>

<br/>
<NonRoutableComponent />

<NonRoutableComponent /> *@
@lblMessage

<button @onclick="HandleClick">Click Me</button>

<!-- Last option is to use \'_Imports.razor\' file to add the namespace and then we can directly use the component without any namespace. -->

@code {
    string lblMessage = string.Empty;
    void HandleClick()
    {
        lblMessage = "You clicked me";
    }
}
